DATABASE_URL="postgresql://user:password@localhost:5432/projectworks?schema=public"
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"
AI_PROVIDER="openai"
OPENAI_API_KEY="sk-..."

# AI section quality gate controls
# Profiles: dev | staging | prod (per-profile defaults can still be overridden below)
AI_SECTION_QUALITY_PROFILE="staging"
AI_SECTION_QUALITY_GATE_ENABLED="true"
AI_SECTION_STRICT_RETRY_ENABLED="true"
AI_SECTION_MAX_RETRIES="1"
AI_SECTION_GENERIC_CHECK_ENABLED="true"

# Optional strictness thresholds
AI_MIN_OVERVIEW_SUMMARY_CHARS="80"
AI_MIN_OVERVIEW_OBJECTIVES="3"
AI_MIN_OVERVIEW_BUDGET_BREAKDOWN="3"
AI_MIN_SCHEDULE_PHASES="4"
AI_MIN_SCHEDULE_MILESTONES="4"
AI_MIN_SCHEDULE_TASKS="10"
AI_MIN_RESOURCES_ROLES="4"
AI_MIN_RESOURCES_LABOUR="3"
AI_MIN_RESOURCES_CONTACTS="3"
AI_MIN_RESOURCES_ORGANOGRAM_CHARS="20"
AI_MIN_PLANT_ITEMS="4"
AI_MIN_QUALITY_ITP_ITEMS="6"
AI_MIN_QUALITY_HOLD_POINTS="3"
AI_MIN_QUALITY_STANDARDS="2"
AI_MIN_RISK_ITEMS="5"
AI_MIN_COMPLIANCE_STANDARDS="3"
AI_MIN_COMPLIANCE_REFERENCES="2"
AI_MIN_PROCUREMENT_ITEMS="5"
AI_MIN_SCOPE_CHARS="180"
