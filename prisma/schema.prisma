datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum PlanTier {
  FREE
  PRO
}

model User {
  id                     String    @id @default(cuid())
  email                  String    @unique
  name                   String?
  passwordHash           String?
  plan                   PlanTier  @default(FREE)
  subscriptionTier       String    @default("free")
  planGenerationsUsed    Int       @default(0)
  subscriptionStart      DateTime?
  subscriptionEnd        DateTime?
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  savedPlans             SavedPlan[]
  projects               Project[]
}

model SavedPlan {
  id        String   @id @default(cuid())
  userId    String
  title     String
  planData  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id         String   @id @default(cuid())
  title      String
  content    Json?    // legacy full plan; used when not using progressive sections
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  overview    Json?
  scope       Json?
  schedule    Json?
  resources   Json?
  procurement Json?
  risk        Json?
  compliance  Json?

  user User @relation(fields: [userId], references: [id])
}
